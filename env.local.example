'use client'

import { useState } from 'react'

const faqs = [
  {
    q: 'Can I use SkillsFuture credits?',
    a: 'Claim your SkillsFuture credits on NUS or SP courses first, then pay us directly in cash. We keep it simple — no bureaucratic delays on our end.',
  },
  {
    q: "What's your guarantee?",
    a: 'Pass our mock assessment or get a 50% refund. No questions asked. We're confident because our mock tests have an 85% correlation with actual AIAP pass rates.',
  },
  {
    q: 'How do I get support?',
    a: 'Self-paced with structured Slack channels and async mentor feedback. No live Zoom calls — learn on your own schedule with expert guidance when you need it.',
  },
]

export default function FAQ() {
  const [openIndex, setOpenIndex] = useState<number | null>(null)

  return (
    <section className="py-24 px-8 max-w-3xl mx-auto">
      <div className="text-center mb-12">
        <h2 className="font-space text-4xl md:text-5xl">Frequently Asked</h2>
      </div>

      <div className="space-y-0">
        {faqs.map((faq, i) => (
          <div
            key={i}
            className="border-b border-border"
          >
            <button
              onClick={() => setOpenIndex(openIndex === i ? null : i)}
              className="w-full flex justify-between items-center py-6 text-left"
            >
              <span className="font-space font-semibold text-lg">{faq.q}</span>
              <span className={`text-aisg-red text-2xl transition-transform duration-300 ${openIndex === i ? 'rotate-45' : ''}`}>
                +
              </span>
            </button>
            <div
              className={`overflow-hidden transition-all duration-300 ${
                openIndex === i ? 'max-h-48 pb-6' : 'max-h-0'
              }`}
            >
              <p className="text-slate">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  )
}
